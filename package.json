{
  "name": "opencode-skill-search",
  "version": "0.1.2",
  "description": "BM25-powered skill search plugin for OpenCode — discover and load agent skills by keyword",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "skill-search",
    "bm25",
    "agent-skills"
  ],
  "license": "MIT",
  "author": "zhan",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhanjian0217/opencode-skill-search"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.3.3",
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  }
}
